{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    { "source": "/journal/:slug", "destination": "/api/journal-article-render?slug=:slug" },
    { "source": "/journal/:slug/", "destination": "/api/journal-article-render?slug=:slug" }
  ]
}
