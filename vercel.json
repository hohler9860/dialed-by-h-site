{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=(), payment=()" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/img",
      "destination": "/api/img"
    },
    {
      "source": "/journal/:slug",
      "destination": "/api/journal-article-render?slug=:slug"
    },
    {
      "source": "/journal/:slug/",
      "destination": "/api/journal-article-render?slug=:slug"
    },
    {
      "source": "/watch/:slug",
      "destination": "/api/get-inventory?slug=:slug"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/get-inventory?sitemap=1"
    }
  ],
  "redirects": [
    {
      "source": "/journal.html",
      "destination": "/journal/",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/inventory",
      "destination": "/buy/",
      "permanent": true
    },
    {
      "source": "/inventory.html",
      "destination": "/buy/",
      "permanent": true
    },
    {
      "source": "/about.html",
      "destination": "/about/",
      "permanent": true
    },
    {
      "source": "/process.html",
      "destination": "/process/",
      "permanent": true
    },
    {
      "source": "/watch.html",
      "destination": "/buy/",
      "permanent": true
    },
    {
      "source": "/watch",
      "destination": "/buy/",
      "permanent": true
    }
  ]
}